# Environment variables for Docker container and docker-compose.yml
# Used by run.sh for model validation and server configuration

# Model configuration
MODEL_NAME=Qwen3.6-35B-A3B-UD-Q3_K_M
MODEL_NAME_ALIAS=qwen3.6
CTX_SIZE=32768
FLASH_ATTN=on
THREADS=6
BATCH_SIZE=1024
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
NO_MMAP=true
PARALLEL=1
CACHE_RAM=0
N_GPU_LAYERS=999

# Server configuration
HOST=0.0.0.0
PORT=8080