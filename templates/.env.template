# Environment variables for Docker container and docker-compose.yml
# Used by run.sh for model validation and server configuration

# Model configuration
MODEL_NAME=Qwen3.6-35B-A3B-UD-Q4_K_XL
MODEL_NAME_ALIAS=qwen3.6-35b
CTX_SIZE=98304
FLASH_ATTN=on
THREADS=5
BATCH_SIZE=256
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
NO_MMAP=false
PARALLEL=1
CACHE_RAM=4096

# Fit / speculative decoding
FIT=on
FIT_TARGET=256
FIT_CTX=98304
UBATCH_SIZE=256
POLL_BATCH=0

# Sampling
TEMP=0.6
TOP_P=0.80
TOP_K=20
MIN_P=0.0

# Penalties
PRESENCE_PENALTY=0.0
REPEAT_PENALTY=1.0

# Features
REASONING=on

# Server configuration
HOST=0.0.0.0
PORT_INTERNAL=8080
PORT_EXTERNAL=8001

# Hardware: force CPU even if NVIDIA GPU is available (on/off)
FORCE_CPU=off