# Environment variables for Docker container and docker-compose.yml
# Used by run.sh for model validation and server configuration

# Model configuration
MODEL_NAME=Qwen3.6-35B-A3B-UD-Q4_K_XL
MODEL_NAME_ALIAS=qwen3.6-35b
CTX_SIZE=65536
FLASH_ATTN=on
THREADS=6
BATCH_SIZE=1024
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
NO_MMAP=true
PARALLEL=1
CACHE_RAM=4096

# Fit / speculative decoding
FIT=on
FIT_TARGET=768
FIT_CTX=65536
UBATCH_SIZE=512
POLL_BATCH=0

# Sampling
TEMP=0.6
TOP_P=0.80
TOP_K=20
MIN_P=0.0

# Penalties
PRESENCE_PENALTY=0.0
REPEAT_PENALTY=1.0

# Features
REASONING=on

# Server configuration
HOST=0.0.0.0
PORT_INTERNAL=8080
PORT_EXTERNAL=8001